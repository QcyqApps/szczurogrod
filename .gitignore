# Capacitor — natywne projekty (apps/web/android, apps/web/ios) commit'ujemy
# żeby zmiany w Manifest/gradle/icons były wersjonowane. Capacitor generuje
# własne `.gitignore` per platforma które wyklucza artefakty buildu (build/,
# .gradle/, app/src/main/assets/public/ itp.).
