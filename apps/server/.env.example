NODE_ENV=development
PORT=4000
HOST=0.0.0.0
DATABASE_URL=postgres://grodno:grodno@localhost:5434/grodno
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
# Required to call admin.* procedures (content reload). Unset = admin disabled.
ADMIN_TOKEN=
# Optional. Enables Claude-generated town flavor texts (20-30 per class per day).
# Unset = server falls back to hardcoded defaults. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=
