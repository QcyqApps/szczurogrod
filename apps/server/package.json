{
  "name": "@grodno/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "types": "./src/routers/index.ts",
  "exports": {
    ".": {
      "types": "./src/routers/index.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b --noEmit",
    "start": "tsx src/index.ts",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@grodno/shared": "workspace:*",
    "@trpc/server": "^11.0.0-rc.648",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.2",
    "fastify": "^5.2.0",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "pino-pretty": "^13.0.0",
    "superjson": "^2.2.1",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "vitest": "^2.1.8"
  }
}
