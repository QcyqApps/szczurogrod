# ===== Szczurogród production env =====
# Skopiuj do `.env` (gitignored) i wypełnij. Docker compose czyta z .env
# w root'cie przy `docker compose --profile app up`.
#
# Lokalny dev (server poza Dockerem) używa `apps/server/.env` osobno.

# JWT — minimum 32 znaki, generuj losowo:
#   openssl rand -base64 48 | tr -d /+= | head -c 64
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING_AT_MINIMUM_32_LONG_PLEASE
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS — origins które mogą uderzać API. Lista po przecinku.
# Web prod: oba frontendowe domeny (ratburg.com + szczurogrod.pl).
# Mobile: http://localhost (Capacitor Android), capacitor://localhost (iOS).
CORS_ORIGIN=http://localhost,https://localhost,capacitor://localhost,https://ratburg.com,https://szczurogrod.pl

# VITE_API_URL — bake'owany w bundle webu pod `docker compose build web`.
# Default w docker-compose to https://tidle.ovh/grodno (prod backend).
# Override na staging/lokalnie: ustaw tu i `docker compose --profile app build web`.
# VITE_API_URL=https://tidle.ovh/grodno

# VITE_PAYPAL_CLIENT_ID — PayPal SDK client-id, bake'owany w bundle webu
# i survivora. Public identifier — bezpiecznie commitować do bundla.
# Live: https://developer.paypal.com/dashboard/applications/live → twoja aplikacja → Client ID.
# Sandbox: tam samo, tab "Sandbox". Bez tego guziki PayPala renderują się
# z fallback'iem clientId='test' i nie obsłużą zakupu.
VITE_PAYPAL_CLIENT_ID=

# ===== PayPal backend =====
# Server-to-server credentials, NIE commitować. Bez tych dwóch zmiennych
# `gemShop.list` zwraca paypalReady:false i klient pokazuje fallback
# „Payments only via Google Play".
PAYPAL_API_KEY=
PAYPAL_SECRET=

# API base — live = api-m.paypal.com, sandbox = api-m.sandbox.paypal.com.
# Default w env.ts to sandbox; PROD MUSI override'ować na live.
PAYPAL_API_BASE=https://api-m.paypal.com

# Webhook ID z PayPal Developer Dashboard → Webhooks. Bez niego endpoint
# /webhooks/paypal odrzuca wszystkie eventy (signature verify fail).
PAYPAL_WEBHOOK_ID=

# Pino log level: trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# Admin token — gate dla `/trpc/admin.reload`. Pozostaw pusty żeby disable.
ADMIN_TOKEN=

# Anthropic API key — używany do flavor text w chronicles. Opcjonalny.
ANTHROPIC_API_KEY=

# ===== Google Play Billing =====
# Package name z apps/web/capacitor.config.ts. Bez tego verifyPlay zwraca
# PLAY_NOT_CONFIGURED.
GOOGLE_PLAY_PACKAGE_NAME=com.ratburg

# Service account JSON content (cały plik jako stringified env). Setup:
# Play Console → Setup → API access → Create service account → JSON key.
# Service account potrzebuje role'i "View financial data" + "Manage orders".
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Alternatywa: ścieżka do pliku JSON zamiast inline'owania.
# GOOGLE_PLAY_SERVICE_ACCOUNT_FILE=/secrets/play-sa.json
