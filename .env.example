# ===== Szczurogród production env =====
# Skopiuj do `.env` (gitignored) i wypełnij. Docker compose czyta z .env
# w root'cie przy `docker compose --profile app up`.
#
# Lokalny dev (server poza Dockerem) używa `apps/server/.env` osobno.

# JWT — minimum 32 znaki, generuj losowo:
#   openssl rand -base64 48 | tr -d /+= | head -c 64
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING_AT_MINIMUM_32_LONG_PLEASE
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS — origins które mogą uderzać API. Lista po przecinku.
# Web prod: domena hostingu webu (jeśli hostujesz oddzielnie od API).
# Mobile: http://localhost (Capacitor Android), capacitor://localhost (iOS).
CORS_ORIGIN=http://localhost,https://localhost,capacitor://localhost,https://szczurogrod.pl

# Pino log level: trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# Admin token — gate dla `/trpc/admin.reload`. Pozostaw pusty żeby disable.
ADMIN_TOKEN=

# Anthropic API key — używany do flavor text w chronicles. Opcjonalny.
ANTHROPIC_API_KEY=
